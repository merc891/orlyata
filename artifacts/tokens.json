{
  "color": {
    "brand": {
      "black": "#0a0a0a",
      "green": "#6ccc47"
    },
    "neutral": {
      "white": "#ffffff",
      "50":  "#f4f4f5",
      "400": "#71717a",
      "950": "#0a0a0a"
    },
    "semantic": {
      "bg/default":     "{color.neutral.white}",
      "bg/muted":       "{color.neutral.50}",
      "bg/inverse":     "{color.brand.black}",
      "text/primary":   "{color.brand.black}",
      "text/secondary": "{color.neutral.400}",
      "text/inverse":   "{color.neutral.white}",
      "accent/default": "{color.brand.green}",
      "border/default": "rgba(0,0,0,0.1)",
      "border/subtle":  "rgba(255,255,255,0.06)"
    }
  },
  "space": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "7": 32,
    "8": 40
  },
  "radius": {
    "sm":   10,
    "md":   16,
    "lg":   24,
    "full": 9999
  },
  "shadow": {
    "card":  "0 1px 2px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.08)",
    "modal": "0 8px 32px rgba(0,0,0,0.18)",
    "focus": "0 0 0 3px rgba(108,204,71,0.4)"
  },
  "typography": {
    "family": {
      "heading": "'Gramatika', sans-serif",
      "body":    "'Gramatika', sans-serif"
    },
    "style": {
      "heading/display": { "family": "heading", "size": 44, "line": 44, "weight": 400, "tracking": -1.32 },
      "heading/xl":      { "family": "heading", "size": 36, "line": 36, "weight": 400, "tracking": -0.72 },
      "heading/lg":      { "family": "heading", "size": 24, "line": 32, "weight": 400, "tracking": -0.48 },
      "body/lg":         { "family": "body",    "size": 18, "line": 27, "weight": 400, "tracking": -0.16 },
      "body/md":         { "family": "body",    "size": 16, "line": 24, "weight": 400, "tracking": -0.16 },
      "body/sm":         { "family": "body",    "size": 14, "line": 21, "weight": 400, "tracking": -0.16 }
    }
  }
}
